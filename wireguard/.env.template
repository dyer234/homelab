TZ=America/Los_Angeles
DOMAIN=dyerwolf.xyz

# Your public hostname or IP - clients connect to this
WG_HOST=vpn.dyerwolf.xyz

# Generate with: docker run -it ghcr.io/wg-easy/wg-easy wgpw 'YOUR_PASSWORD'
PASSWORD_HASH='$2a$12$mE2bVxmJ4x6gHldyYhivTO2KLlTgHzOA0Y9ZgNq2Kuox4FzTY5Q9K'

# DNS for connected clients (use your network's DNS or a public one)
WG_DEFAULT_DNS=1.1.1.1

# Route all traffic through VPN (default) - keeps users safe on sketchy networks
# To also access LAN resources, the server's network handles it via ip_forward
WG_ALLOWED_IPS=0.0.0.0/0, ::/0

# Keepalive to maintain NAT traversal (seconds)
WG_PERSISTENT_KEEPALIVE=25
